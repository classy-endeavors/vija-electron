{
  "manifest_version": 3,
  "minimum_chrome_version": "114",
  "name": "Vijia Browser Bridge",
  "version": "0.1.0",
  "description": "Guide Mode and browser bridge: step-by-step guidance and AI chat context to Vijia.",
  "permissions": ["contextMenus", "storage", "tabs", "sidePanel"],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "host_permissions": [
    "http://127.0.0.1/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://chat.deepseek.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Vijia Browser Bridge"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://chat.deepseek.com/*"
      ],
      "js": ["site-adapters.js", "debug-overlay.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
