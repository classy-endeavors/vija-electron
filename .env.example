# Copy to `.env` or `.env.local` and fill in values. Vite/electron-vite load these
# for dev and build. Git ignores `.env` and `.env.local` — do not commit secrets.

# --- Supabase (required for claude-proxy and the renderer API client) ----------
# Project Settings → API in the Supabase dashboard
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Browser extension bridge (optional) --------------------------------------
# Port for the local HTTP server the extension posts captures to. Default: 45731
# VIJIA_EXTENSION_BRIDGE_PORT=45731

# Optional; if unset, a token in `.vijia/browser-extension-bridge.json` (or
# `VIJIA_BRIDGE_REPO_DIR` below) is used. Must match the extension’s session token.
# VIJIA_EXTENSION_TOKEN=

# --- Main process debug logs (optional) --------------------------------------
# `1`, `true`, or `yes`: enable `[Vijia][debug]` and proactive `console` output
# in the Electron main process. No other source (e.g. dev vs packaged).
# Add to `.env` / `.env.local` and restart `npm run dev` so the main bundle sees it.
# VIJIA_DEBUG=1

# `1` / `true` / `yes`: skip proactive + overlay notification throttles (dev/QA only).
# VIJIA_DISABLE_COOLDOWNS=1

# `1` / `true` / `yes`: proactive user message always instructs the model to return
# `should_speak: true` with a contextual message (force-speak prompt; dev/QA).
# You can also set `PROACTIVE_FORCE_SPEAK_PROMPT_IN_CODE` in `proactive-engine.ts`.
# VIJIA_PROACTIVE_FORCE_SPEAK=1

# --- Local storage override (dev only) -----------------------------------------
# If set, Vijia reads/writes `<this path>` instead of `cwd/.vijia` in development.
# Packaged app always uses the OS user data directory; this flag is ignored there.
# VIJIA_BRIDGE_REPO_DIR=/absolute/path/to/.vijia
